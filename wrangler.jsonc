{
  // Cloudflare Workers config: serves the built VitePress docs as a
  // static-assets-only Worker (no script). Deployed by Workers Builds
  // with: build = `npm run docs:build`, deploy = `npx wrangler deploy`.
  "name": "rankbeam-docs",
  "compatibility_date": "2026-06-12",
  "assets": {
    "directory": "./docs/.vitepress/dist",
    "not_found_handling": "404-page"
  }
}
