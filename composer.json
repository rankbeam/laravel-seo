{
    "name": "rankbeam/laravel-seo",
    "description": "Open-core SEO infrastructure for Laravel: metadata, canonical URLs, social cards, linked JSON-LD, XML sitemaps and crawler controls - the free MIT core.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "php",
        "seo",
        "meta-tags",
        "open-graph",
        "twitter-cards",
        "structured-data",
        "json-ld",
        "schema",
        "sitemap",
        "canonical"
    ],
    "authors": [
        {
            "name": "Valentin Goxhaj",
            "email": "valentinogoxhaj@gmail.com"
        }
    ],
    "homepage": "https://rankbeam.dev",
    "support": {
        "issues": "https://github.com/rankbeam/laravel-seo/issues",
        "source": "https://github.com/rankbeam/laravel-seo",
        "docs": "https://docs.rankbeam.dev",
        "email": "hello@rankbeam.dev"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "laravel/pint": "^1.0",
        "spatie/browsershot": "^4.0|^5.0",
        "spatie/laravel-sitemap": "^7.0|^8.0"
    },
    "suggest": {
        "spatie/browsershot": "Generate 1200x630 OG images with a real browser (config seo.og_image)",
        "spatie/laravel-sitemap": "Generate XML sitemaps for your models (^7.0|^8.0)"
    },
    "autoload": {
        "psr-4": {
            "Rankbeam\\Seo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rankbeam\\Seo\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "3.x-dev"
        },
        "laravel": {
            "providers": [
                "Rankbeam\\Seo\\SEOServiceProvider"
            ],
            "aliases": {
                "SEO": "Rankbeam\\Seo\\Facades\\SEO"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    }
}
